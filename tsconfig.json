{
  "compilerOptions": {
    "moduleResolution":"nodenext",
    "module": "NodeNext",
    "target": "ESNext",
    "rootDir": "./src",
    "outDir": "./dst",
    "types": [ "node", "jest" ],
    "strict": true,
    "removeComments": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["./src"],
  "exclude": ["node_modules", "dst"]
}
